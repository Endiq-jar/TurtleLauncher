{
  "name": "FPS Preset",
  "description": "Optimized for FPS: low latency, high FPS, reduced GC pauses.",
  "javaArgs": "-XX:+UseG1GC -XX:MaxGCPauseMillis=4 -XX:G1HeapRegionSize=16M -XX:+UnlockExperimentalVMOptions -XX:G1NewSizePercent=40 -XX:G1ReservePercent=20 -XX:+DisableExplicitGC -Dorg.lwjgl.util.NoChecks=true",
  "ramAllocation": 1024,
  "unlimitedFps": true,
  "lowLatencyRendering": true,
  "framePacing": true,
  "frameSkipping": true,
  "adaptiveFrameTiming": true
}
