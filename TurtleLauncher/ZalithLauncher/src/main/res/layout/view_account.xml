<?xml version="1.0" encoding="utf-8"?>
<com.movtery.zalithlauncher.ui.layout.AnimConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/background_grid_card"
    android:padding="@dimen/space_m">

    <ImageView
        android:id="@+id/user_icon"
        android:layout_width="@dimen/_44sdp"
        android:layout_height="@dimen/_44sdp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_help"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/user_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_s"
        android:singleLine="true"
        android:ellipsize="end"
        android:textSize="@dimen/_14ssp"
        android:textStyle="bold"
        android:textColor="@color/turtle_text_primary"
        app:layout_constraintStart_toEndOf="@id/user_icon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/user_icon"
        app:layout_constraintBottom_toTopOf="@id/account_type"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="Test Name" />

    <TextView
        android:id="@+id/account_type"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_s"
        android:singleLine="true"
        android:ellipsize="end"
        android:textSize="@dimen/_11ssp"
        android:textColor="@color/turtle_text_secondary"
        app:layout_constraintStart_toEndOf="@id/user_icon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/user_name"
        app:layout_constraintBottom_toBottomOf="@id/user_icon"
        tools:text="LittleSkin"/>

</com.movtery.zalithlauncher.ui.layout.AnimConstraintLayout>
