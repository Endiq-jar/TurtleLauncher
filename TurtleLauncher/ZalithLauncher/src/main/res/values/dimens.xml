<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Padding -->
    <dimen name="padding_small">@dimen/_2sdp</dimen>
    <dimen name="padding_medium">@dimen/_4sdp</dimen>
    <dimen name="padding_moderate">@dimen/_6sdp</dimen>
    <dimen name="padding_heavy">@dimen/_12sdp</dimen>
    <dimen name="padding_large">@dimen/_16sdp</dimen>
    <dimen name="padding_extra_large">@dimen/_24sdp</dimen>
    <!-- Input text padding -->
    <dimen name="padding_input_bottom">@dimen/padding_heavy</dimen>
    <dimen name="padding_input_top">@dimen/_11sdp</dimen>
    <!--  Dialog min width  -->
    <dimen name="dialog_min_width">@dimen/_480sdp</dimen>

    <!-- ── Unified corner-radius scale (clean, minimal, consistent) ─────
         Use these instead of one-off literals so every card/button/chip
         in the app shares the same rounding language.                  -->
    <dimen name="radius_chip">8dp</dimen>
    <dimen name="radius_item">12dp</dimen>
    <dimen name="radius_panel">20dp</dimen>
    <dimen name="radius_dialog">24dp</dimen>

    <!-- ── Spacing scale (minimal, 4dp baseline grid) ───────────────── -->
    <dimen name="space_xs">4dp</dimen>
    <dimen name="space_s">8dp</dimen>
    <dimen name="space_m">12dp</dimen>
    <dimen name="space_l">16dp</dimen>
    <dimen name="space_xl">24dp</dimen>

    <!-- ── Elevation ─────────────────────────────────────────────────── -->
    <dimen name="elevation_flat">0dp</dimen>
    <dimen name="elevation_card">2dp</dimen>
    <dimen name="elevation_dialog">8dp</dimen>
</resources>
