<?xml version="1.0" encoding="utf-8"?>
<!-- TurtleLauncher glass card: used across popups/cards app-wide.
     Layered translucency + soft top highlight + glowing accent edge = glassmorphism. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="@color/bg_card" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="@color/turtle_glass_overlay"
                android:centerColor="#00000000"
                android:endColor="#00000000" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <stroke android:width="1dp" android:color="@color/turtle_border_default" />
        </shape>
    </item>
</layer-list>
