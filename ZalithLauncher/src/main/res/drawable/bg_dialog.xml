<?xml version="1.0" encoding="utf-8"?>
<!-- TurtleLauncher glass surface: layered translucency simulates a frosted-glass card
     (Android shapes can't sample the real background to blur it, so this fakes the
     "glass" look with a dark translucent fill, a soft light gradient across the top
     to suggest a glossy highlight, and a thin glowing accent border). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base translucent glass fill -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="@color/turtle_surface" />
        </shape>
    </item>
    <!-- Soft glossy highlight across the top, like light hitting glass -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="@color/turtle_glass_overlay"
                android:centerColor="#00000000"
                android:endColor="#00000000" />
        </shape>
    </item>
    <!-- Outer glowing accent stroke -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="@color/turtle_stroke" />
        </shape>
    </item>
</layer-list>
