<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dialog_background">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_16sdp">

        <!-- Header row -->
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/_12sdp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/whats_new_title"
                android:textColor="@color/turtle_success"
                android:textSize="@dimen/_18ssp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/close_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="@color/turtle_error"
                android:textSize="@dimen/_18ssp"
                android:padding="@dimen/_4sdp"
                android:background="?android:attr/selectableItemBackgroundBorderless"/>

        </androidx.appcompat.widget.LinearLayoutCompat>

        <!-- Version badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/whats_new_version"
            android:textColor="@color/accent_primary"
            android:textSize="@dimen/_13ssp"
            android:textStyle="bold"
            android:background="@color/turtle_accent_ripple"
            android:paddingHorizontal="@dimen/_8sdp"
            android:paddingVertical="@dimen/_4sdp"
            android:layout_marginBottom="@dimen/_12sdp"/>

        <!-- Feature: Skin / Cape -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/whats_new_skin_cape"
            android:textColor="@color/turtle_success"
            android:textSize="@dimen/_14ssp"
            android:textStyle="bold"
            android:drawablePadding="@dimen/_6sdp"
            android:layout_marginBottom="@dimen/_4sdp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/whats_new_skin_cape_desc"
            android:textColor="@color/turtle_text_secondary"
            android:textSize="@dimen/_12ssp"
            android:layout_marginBottom="@dimen/_12sdp"/>

        <!-- Feature: Other Login -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/whats_new_other_login"
            android:textColor="@color/turtle_success"
            android:textSize="@dimen/_14ssp"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/_4sdp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/whats_new_other_login_desc"
            android:textColor="@color/turtle_text_secondary"
            android:textSize="@dimen/_12ssp"
            android:layout_marginBottom="@dimen/_12sdp"/>

        <!-- Feature: PvP / Survival Presets -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/whats_new_presets"
            android:textColor="@color/turtle_success"
            android:textSize="@dimen/_14ssp"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/_4sdp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/whats_new_presets_desc"
            android:textColor="@color/turtle_text_secondary"
            android:textSize="@dimen/_12ssp"
            android:layout_marginBottom="@dimen/_12sdp"/>

        <!-- Warning note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/whats_new_warning"
            android:textColor="@color/turtle_warning"
            android:textSize="@dimen/_11ssp"
            android:layout_marginTop="@dimen/_4sdp"/>

    </androidx.appcompat.widget.LinearLayoutCompat>

</androidx.core.widget.NestedScrollView>
