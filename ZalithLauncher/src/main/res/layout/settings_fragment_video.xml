<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_app"
    tools:ignore="UseSwitchCompatOrMaterialXml">

    <LinearLayout
        android:id="@+id/sub_settings_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/space_l"
        android:paddingVertical="@dimen/space_m">

        <ImageButton
            android:id="@+id/sub_settings_back_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_chevron_down"
            android:rotation="90"
            android:tint="@color/turtle_text_secondary"
            android:contentDescription="@string/generic_return"/>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="@dimen/space_s"
            android:src="@drawable/ic_setting_video"
            android:tint="@color/accent_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_s"
            android:text="@string/setting_category_video"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/turtle_text_primary"/>
    </LinearLayout>

    <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:ignore="UseSwitchCompatOrMaterialXml">
    
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_12sdp"
            android:orientation="vertical"
            android:paddingVertical="@dimen/_12sdp">
    
            <!-- ═══════════════════════════════════════════════════════════
                 VIDEO SETTINGS CARD
            ════════════════════════════════════════════════════════════════ -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/video_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_card"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/_2sdp"
                android:paddingVertical="@dimen/_12sdp">
    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_12sdp"
                    android:text="@string/setting_category_video"
                    android:textColor="@color/accent_primary" />
    
                <!-- Graphics Backend (simplified Vulkan/OpenGL switch) -->
                <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                    android:id="@+id/graphics_backend_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/_12sdp">
    
                    <TextView
                        android:id="@+id/graphics_backend_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:text="@string/setting_graphics_backend_title"
                        android:textColor="@color/turtle_primary_text" />
    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/graphics_backend_title"
                        android:layout_marginBottom="@dimen/_8sdp"
                        android:text="@string/setting_graphics_backend_summary"
                        android:textSize="@dimen/_11ssp"
                        android:textColor="@color/turtle_text_secondary" />
    
                    <LinearLayout
                        android:id="@+id/graphics_backend_buttons"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/graphics_backend_title"
                        android:layout_marginTop="@dimen/_28sdp"
                        android:orientation="horizontal">
    
                        <com.movtery.zalithlauncher.ui.view.AnimButton
                            android:id="@+id/graphics_backend_opengl"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/_4sdp"
                            android:textSize="@dimen/_12ssp"
                            android:text="@string/setting_graphics_backend_opengl"/>
    
                        <com.movtery.zalithlauncher.ui.view.AnimButton
                            android:id="@+id/graphics_backend_vulkan"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="@dimen/_12ssp"
                            android:text="@string/setting_graphics_backend_vulkan"/>
    
                    </LinearLayout>
                </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>
    
                <!-- Renderer -->
                <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                    android:id="@+id/renderer_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="@dimen/_12sdp">
    
                    <TextView
                        android:id="@+id/renderer_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/renderer_download"
                        android:text="@string/setting_renderer_title"
                        android:textColor="@color/turtle_primary_text" />
    
                    <TextView
                        android:id="@+id/renderer_value"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_below="@+id/renderer_title"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/renderer_download"
                        android:text="@string/generic_default" />
    
                    <ImageButton
                        android:id="@+id/renderer_download"
                        android:layout_width="@dimen/_32sdp"
                        android:layout_height="@dimen/_32sdp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/setting_category_download"
                        android:src="@drawable/ic_download"
                        android:background="?android:attr/selectableItemBackgroundBorderless"/>
                </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>
    
                <!-- Local Renderer Import -->
                <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                    android:id="@+id/renderer_local_import_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="@dimen/_12sdp">
    
                    <TextView
                        android:id="@+id/renderer_local_import_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/renderer_local_import_manage"
                        android:text="@string/setting_renderer_local_import_title"
                        android:textColor="@color/turtle_primary_text" />
    
                    <TextView
                        android:id="@+id/renderer_local_import_summary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_below="@+id/renderer_local_import_title"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/renderer_local_import_manage"
                        android:text="@string/setting_renderer_local_import_desc" />
    
                    <ImageButton
                        android:id="@+id/renderer_local_import_manage"
                        android:layout_width="@dimen/_32sdp"
                        android:layout_height="@dimen/_32sdp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/setting_renderer_local_manage"
                        android:src="@drawable/ic_setting"
                        android:background="?android:attr/selectableItemBackgroundBorderless"/>
                </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>
    
                <!-- Driver -->
                <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                    android:id="@+id/driver_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="@dimen/_12sdp">
    
                    <TextView
                        android:id="@+id/driver_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/driver_download"
                        android:text="@string/setting_driver_title"
                        android:textColor="@color/turtle_primary_text" />
    
                    <TextView
                        android:id="@+id/driver_value"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_below="@+id/driver_title"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/driver_download"
                        android:text="@string/generic_default" />
    
                    <ImageButton
                        android:id="@+id/driver_download"
                        android:layout_width="@dimen/_32sdp"
                        android:layout_height="@dimen/_32sdp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/setting_category_download"
                        android:src="@drawable/ic_download"
                        android:background="?android:attr/selectableItemBackgroundBorderless"/>
                </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>
    
                <!-- Ignore Notch -->
                <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                    android:id="@+id/ignoreNotch_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="@dimen/_12sdp">
    
                    <TextView
                        android:id="@+id/ignoreNotch_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_toStartOf="@+id/ignoreNotch"
                        android:text="@string/setting_ignore_notch_title"
                        android:textColor="@color/turtle_primary_text" />
    
                    <TextView
                        android:id="@+id/ignoreNotch_summary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/ignoreNotch_title"
                        android:layout_alignParentStart="true"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_toStartOf="@+id/ignoreNotch"
                        android:text="@string/setting_ignore_notch_desc" />
    
                    <Switch
                        android:id="@+id/ignoreNotch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true" />
                </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>
    
                <!-- Ignore Notch Launcher -->
                <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                    android:id="@+id/ignoreNotchLauncher_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="@dimen/_12sdp">
    
                    <TextView
                        android:id="@+id/ignoreNotchLauncher_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_toStartOf="@+id/ignoreNotchLauncher"
                        android:text="@string/setting_launcher_ignore_notch_title"
                        android:textColor="@color/turtle_primary_text" />
    
                    <TextView
                        android:id="@+id/ignoreNotchLauncher_summary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/ignoreNotchLauncher_title"
                        android:layout_alignParentStart="true"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_toStartOf="@+id/ignoreNotchLauncher"
                        android:text="@string/setting_launcher_ignore_notch_desc" />
    
                    <Switch
                        android:id="@+id/ignoreNotchLauncher"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true" />
                </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>
    
                <!-- Resolution Ratio -->
                <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                    android:id="@+id/resolutionRatio_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground">
    
                    <TextView
                        android:id="@+id/resolutionRatio_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentEnd="true"
                        android:layout_marginHorizontal="@dimen/_12sdp"
                        android:layout_marginTop="@dimen/_12sdp"
                        android:text="@string/setting_resolution_scaler_title"
                        android:textColor="@color/turtle_primary_text" />
    
                    <TextView
                        android:id="@+id/resolutionRatio_summary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/resolutionRatio_title"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentEnd="true"
                        android:layout_marginHorizontal="@dimen/_12sdp"
                        android:text="@string/setting_resolution_scaler_desc" />
    
                    <SeekBar
                        android:id="@+id/resolutionRatio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignTop="@+id/resolutionRatio_value"
                        android:layout_alignBottom="@+id/resolutionRatio_value"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/resolutionRatio_preview"
                        android:max="300"
                        android:min="25" />
    
                    <TextView
                        android:id="@+id/resolutionRatio_preview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/resolutionRatio_summary"
                        android:layout_toStartOf="@id/resolutionRatio_value"
                        android:layout_marginVertical="@dimen/_8sdp"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:background="@drawable/background_text"
                        tools:text="0 x 0" />
    
                    <TextView
                        android:id="@+id/resolutionRatio_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/resolutionRatio_summary"
                        android:layout_alignParentEnd="true"
                        android:layout_marginVertical="@dimen/_8sdp"
                        android:layout_marginEnd="@dimen/_12sdp"
                        android:background="@drawable/background_text"
                        tools:text="0" />
                </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>
    
                <!-- TurtleLauncher v10: quick resolution presets + auto-detect -->
                <LinearLayout
                    android:id="@+id/resolutionPresets_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_12sdp"
                    android:layout_marginBottom="@dimen/_8sdp"
                    android:orientation="horizontal">
    
                    <Button
                        android:id="@+id/resolutionPreset100"
                        style="@style/TurtleButtonOutline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_4sdp"
                        android:layout_weight="1"
                        android:text="1x"
                        android:textAllCaps="false" />
    
                    <Button
                        android:id="@+id/resolutionPreset75"
                        style="@style/TurtleButtonOutline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_4sdp"
                        android:layout_weight="1"
                        android:text="0.75x"
                        android:textAllCaps="false" />
    
                    <Button
                        android:id="@+id/resolutionPreset50"
                        style="@style/TurtleButtonOutline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_4sdp"
                        android:layout_weight="1"
                        android:text="0.5x"
                        android:textAllCaps="false" />
    
                    <Button
                        android:id="@+id/resolutionAutoDetectButton"
                        style="@style/TurtleButtonOutline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.4"
                        android:text="@string/setting_resolution_auto_detect"
                        android:textAllCaps="false" />
                </LinearLayout>
    
                <!-- Sustained Performance -->
                <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                    android:id="@+id/sustainedPerformance_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="@dimen/_12sdp">
    
                    <TextView
                        android:id="@+id/sustainedPerformance_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_toStartOf="@+id/sustainedPerformance"
                        android:text="@string/setting_sustained_performance_title"
                        android:textColor="@color/turtle_primary_text" />
    
                    <TextView
                        android:id="@+id/sustainedPerformance_summary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/sustainedPerformance_title"
                        android:layout_alignParentStart="true"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_toStartOf="@+id/sustainedPerformance"
                        android:text="@string/setting_limit_overheating_throttling" />
    
                    <Switch
                        android:id="@+id/sustainedPerformance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>
    
                <!-- Alternate Surface -->
                <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                    android:id="@+id/alternate_surface_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="@dimen/_12sdp">
    
                    <TextView
                        android:id="@+id/alternate_surface_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_toStartOf="@+id/alternate_surface"
                        android:text="@string/setting_use_surface_view_title"
                        android:textColor="@color/turtle_primary_text" />
    
                    <TextView
                        android:id="@+id/alternate_surface_summary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/alternate_surface_title"
                        android:layout_alignParentStart="true"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_toStartOf="@+id/alternate_surface"
                        android:text="@string/setting_use_surface_view_desc" />
    
                    <Switch
                        android:id="@+id/alternate_surface"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>
    
                <!-- Force VSync -->
                <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                    android:id="@+id/force_vsync_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="@dimen/_12sdp">
    
                    <TextView
                        android:id="@+id/force_vsync_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_toStartOf="@+id/force_vsync"
                        android:text="@string/setting_force_vsync_title"
                        android:textColor="@color/turtle_primary_text" />
    
                    <TextView
                        android:id="@+id/force_vsync_summary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/force_vsync_title"
                        android:layout_alignParentStart="true"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_toStartOf="@+id/force_vsync"
                        android:text="@string/setting_limit_overheating_throttling" />
    
                    <Switch
                        android:id="@+id/force_vsync"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>
    
                <!-- VSync in Zink -->
                <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                    android:id="@+id/vsync_in_zink_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="@dimen/_12sdp">
    
                    <TextView
                        android:id="@+id/vsync_in_zink_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_toStartOf="@+id/vsync_in_zink"
                        android:text="@string/setting_vsync_in_zink_title"
                        android:textColor="@color/turtle_primary_text" />
    
                    <TextView
                        android:id="@+id/vsync_in_zink_summary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/vsync_in_zink_title"
                        android:layout_alignParentStart="true"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_toStartOf="@+id/vsync_in_zink"
                        android:text="@string/setting_vsync_in_zink_desc" />
    
                    <Switch
                        android:id="@+id/vsync_in_zink"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>
    
                <!-- Zink Prefer System Driver -->
                <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                    android:id="@+id/zinkPreferSystemDriver_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="@dimen/_12sdp">
    
                    <TextView
                        android:id="@+id/zinkPreferSystemDriver_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_toStartOf="@+id/zinkPreferSystemDriver"
                        android:text="@string/setting_vulkan_driver_system_title"
                        android:textColor="@color/turtle_primary_text" />
    
                    <TextView
                        android:id="@+id/zinkPreferSystemDriver_summary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/zinkPreferSystemDriver_title"
                        android:layout_alignParentStart="true"
                        android:layout_marginEnd="@dimen/_8sdp"
                        android:layout_toStartOf="@+id/zinkPreferSystemDriver"
                        android:text="@string/setting_vulkan_driver_system_desc" />
    
                    <Switch
                        android:id="@+id/zinkPreferSystemDriver"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>
    
            </androidx.appcompat.widget.LinearLayoutCompat>
    
            <!-- ═══════════════════════════════════════════════════════════
                 AUTO GRAPHICS OPTIMIZER CARD  (from Zyron)
            ════════════════════════════════════════════════════════════════ -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/auto_graphics_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_8sdp"
                android:background="@drawable/background_card"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/_2sdp"
                android:paddingVertical="@dimen/_12sdp">
    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_12sdp"
                    android:text="@string/setting_category_auto_graphics"
                    android:textColor="@color/accent_primary" />
    
                <!-- Auto Settings Optimizer -->
                <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                    android:id="@+id/autoSettingsOptimizer_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="@dimen/_12sdp">
    
                    <TextView
