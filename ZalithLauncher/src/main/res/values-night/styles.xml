<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- TurtleLauncher: disable all activity-level transitions for instant navigation -->
        <item name="android:windowAnimationStyle">@style/NoAnimations</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/bg_deep</item>
        <item name="android:windowBackground">@color/bg_deep</item>
        <item name="android:scrollbarThumbHorizontal">@color/accent_primary</item>
        <item name="android:scrollbarThumbVertical">@color/accent_primary</item>
        <item name="android:textSize">@dimen/_12ssp</item>
        <item name="android:textColor">@color/turtle_text_primary</item>
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryDark">@color/bg_deep</item>
        <item name="colorAccent">@color/turtle_accent_glow</item>
        <item name="colorSurface">@color/turtle_bg_surface</item>
        <item name="colorOnSurface">@color/turtle_text_primary</item>
        <item name="colorSurfaceVariant">@color/turtle_bg_elevated</item>
        <item name="colorOutline">@color/turtle_border_default</item>
        <item name="colorError">@color/turtle_error</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <!-- MD3 shape system: rounder, smoother corners app-wide -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Turtle.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Turtle.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Turtle.Large</item>
    </style>

    <!-- MD3 shape tokens — smooth, generously rounded edges -->
    <style name="ShapeAppearance.Turtle.Small" parent="ShapeAppearance.Material3.Corner.Small">
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeAppearance.Turtle.Medium" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerSize">20dp</item>
    </style>
    <style name="ShapeAppearance.Turtle.Large" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerSize">28dp</item>
    </style>

    <style name="CustomDialogStyle" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@drawable/bg_dialog</item>
        <item name="android:windowAnimationStyle">@style/DialogAnimation</item>
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorSurface">@color/turtle_bg_surface</item>
        <item name="colorOnSurface">@color/turtle_text_primary</item>
        <item name="android:scrollbarThumbVertical">@color/accent_primary</item>
        <item name="android:textColor">@color/turtle_text_primary</item>
    </style>

    <style name="CustomAlertDialogTheme" parent="Theme.Material3.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_dialog</item>
        <item name="android:windowAnimationStyle">@style/DialogAnimation</item>
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorSurface">@color/turtle_bg_surface</item>
        <item name="android:textColor">@color/turtle_text_primary</item>
    </style>

    <!-- Premium dialog/popup entrance & exit: soft scale + fade, MD3-style motion -->
    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/dialog_enter</item>
        <item name="android:windowExitAnimation">@anim/dialog_exit</item>
    </style>

    <style name="RoundedCornersImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="RoundImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Gaming Button -->
    <style name="TurtleButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="android:textColor">@color/turtle_text_on_accent</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/radius_item</item>
        <item name="rippleColor">@color/turtle_accent_ripple</item>
    </style>

    <!-- Outlined Button -->
    <style name="TurtleButtonOutline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/accent_primary</item>
        <item name="android:textColor">@color/accent_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/radius_item</item>
        <item name="rippleColor">@color/turtle_accent_ripple</item>
    </style>

    <!-- Zero-duration animation style: removes all activity enter/exit animations -->
    <style name="NoAnimations" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@null</item>
        <item name="android:activityOpenExitAnimation">@null</item>
        <item name="android:activityCloseEnterAnimation">@null</item>
        <item name="android:activityCloseExitAnimation">@null</item>
        <item name="android:taskOpenEnterAnimation">@null</item>
        <item name="android:taskOpenExitAnimation">@null</item>
        <item name="android:taskCloseEnterAnimation">@null</item>
        <item name="android:taskCloseExitAnimation">@null</item>
        <item name="android:taskToFrontEnterAnimation">@null</item>
        <item name="android:taskToFrontExitAnimation">@null</item>
        <item name="android:taskToBackEnterAnimation">@null</item>
        <item name="android:taskToBackExitAnimation">@null</item>
    </style>
    <style name="SettingsSectionHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/turtle_text_secondary</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:paddingHorizontal">4dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:paddingTop">4dp</item>
    </style>
</resources>